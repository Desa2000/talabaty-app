datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  OPERATIONS
  FINANCE
  SUPPORT
  CUSTOMER
  MERCHANT
  COURIER
}

enum VehicleType {
  BICYCLE
  ELECTRIC_BICYCLE
  MOTORCYCLE
}

enum CourierStatus {
  OFFLINE
  AVAILABLE
  BUSY
  SUSPENDED
}

enum CourierVerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MerchantStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum StoreCategory {
  RESTAURANT
  SUPERMARKET
  PHARMACY
}

enum OrderStatus {
  PENDING_MERCHANT
  MERCHANT_ACCEPTED
  PREPARING
  READY_FOR_PICKUP
  SEARCHING_COURIER
  COURIER_ASSIGNED
  COURIER_ACCEPTED
  COURIER_TO_MERCHANT
  AT_MERCHANT
  PICKED_UP
  ON_THE_WAY
  ARRIVED
  DELIVERED
  COMPLETED
  MERCHANT_REJECTED
  CUSTOMER_CANCELLED
  COURIER_CANCELLED
  FAILED
}

enum PaymentMethod {
  CASH
  BANKAK
}

enum PaymentStatus {
  UNPAID
  PAID
  FAILED
  REFUNDED
  BANKAK_PENDING
  BANKAK_SUBMITTED
  BANKAK_VERIFIED
  BANKAK_REJECTED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model User {
  id              String           @id @default(uuid())
  name            String
  phone           String           @unique
  email           String?          @unique
  passwordHash    String
  role            UserRole
  isVerified           Boolean          @default(false)
  isActive             Boolean          @default(true)
  forcePasswordChange  Boolean          @default(false)
  firstTimeSetupCompleted Boolean       @default(false)
  activationTokenHash  String?
  activationTokenExpiresAt DateTime?
  failedLoginAttempts  Int              @default(0)
  lockoutUntil         DateTime?
  tokenVersion         Int              @default(1)
  passwordChangedAt    DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  customerProfile CustomerProfile?
  merchantProfile MerchantProfile?
  courierProfile  CourierProfile?
  adminProfile    AdminProfile?
  
  addresses       Address[]
  deviceTokens    DeviceToken[]
  refreshTokens   RefreshToken[]

  // Order relationships
  customerOrders  Order[]          @relation("CustomerOrders")
  courierOrders   Order[]          @relation("CourierOrders")
}

model CustomerProfile {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  defaultAddressId String?
}

model MerchantProfile {
  id                  String         @id @default(uuid())
  userId              String         @unique
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName        String
  businessDescription String?
  businessArea        String?
  status              MerchantStatus @default(PENDING)
  verificationDocs    String?
  stores              Store[]
}

model CourierProfile {
  id                   String                    @id @default(uuid())
  userId               String                    @unique
  user                 User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicleType          VehicleType
  idNumber             String
  licenseNumber        String?
  verificationStatus   CourierVerificationStatus @default(PENDING)
  status               CourierStatus             @default(OFFLINE)
  isOnline             Boolean                   @default(false)
  currentLatitude      Float?
  currentLongitude     Float?
  lastLocationUpdate   DateTime?
}

model AdminProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Store {
  id                String          @id @default(uuid())
  merchantId        String
  merchant          MerchantProfile @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  name              String
  description       String?
  logoUrl           String?
  coverUrl          String?
  address           String?
  latitude          Float?
  longitude         Float?
  category          StoreCategory
  isOpen            Boolean         @default(true)
  isActive          Boolean         @default(true)
  deliveryFee       Float           @default(500.0)
  minOrderAmount    Float           @default(0.0)
  estimatedPrepTime Int             @default(20) // in minutes
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  products          Product[]
  categories        ProductCategory[]
  orders            Order[]
}

model ProductCategory {
  id        String    @id @default(uuid())
  storeId   String?
  store     Store?    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  nameAr    String
  nameEn    String?
  products  Product[]
}

model Product {
  id               String           @id @default(uuid())
  storeId          String
  store            Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  categoryId       String?
  category         ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  nameAr           String
  nameEn           String?
  descriptionAr    String?
  descriptionEn    String?
  price            Float
  discountPrice    Float?
  imageUrl         String?
  isAvailable      Boolean          @default(true)
  stock            Int              @default(100)
  unit             String?          @default("piece")
  preparationNotes String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  orderItems       OrderItem[]
}

model Address {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String   // e.g., 'البيت', 'الشغل'
  city       String   @default("الخرطوم")
  area       String
  street     String
  landmark   String?
  latitude   Float
  longitude  Float
  phone      String
  createdAt  DateTime @default(now())
}

model Order {
  id                String               @id @default(uuid())
  orderNumber       String               @unique // e.g., TLB-10001
  customerId        String
  customer          User                 @relation("CustomerOrders", fields: [customerId], references: [id], onDelete: Restrict)
  storeId           String
  store             Store                @relation(fields: [storeId], references: [id], onDelete: Restrict)
  courierId         String?
  courier           User?                @relation("CourierOrders", fields: [courierId], references: [id], onDelete: SetNull)
  status            OrderStatus          @default(PENDING_MERCHANT)
  subtotal          Float
  deliveryFee       Float
  discount          Float                @default(0.0)
  total             Float
  paymentMethod     PaymentMethod        @default(CASH)
  paymentStatus     PaymentStatus        @default(UNPAID)
  deliveryAddress   String
  deliveryLatitude  Float
  deliveryLongitude Float
  customerNotes     String?
  merchantNotes     String?
  courierNotes      String?
  bankakProofImage  String?
  bankakTxnRef      String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  items             OrderItem[]
  statusHistory     OrderStatusHistory[]
  payments          Payment[]
  locationLogs      CourierLocationLog[]
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  productName String
  unitPrice   Float
  quantity    Int
  subtotal    Float
}

model OrderStatusHistory {
  id         String      @id @default(uuid())
  orderId    String
  order      Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus OrderStatus?
  toStatus   OrderStatus
  actorType  UserRole
  actorId    String
  timestamp  DateTime    @default(now())
  note       String?
  metadata   String?
}

model Payment {
  id             String        @id @default(uuid())
  orderId        String
  order          Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  paymentMethod  PaymentMethod
  paymentStatus  PaymentStatus @default(UNPAID)
  amount         Float
  transactionId  String?
  receiptUrl     String?
  createdAt      DateTime      @default(now())
}

model CourierLocationLog {
  id        String   @id @default(uuid())
  courierId String
  orderId   String?
  order     Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  latitude  Float
  longitude Float
  heading   Float?   @default(0.0)
  speed     Float?   @default(0.0)
  createdAt DateTime @default(now())
}

model ServiceArea {
  id                 String   @id @default(uuid())
  state              String   // e.g. "ولاية الخرطوم"
  locality           String   // e.g. "الخرطوم", "بحري", "أم درمان"
  nameAr             String
  nameEn             String?
  isActive           Boolean  @default(true)
  deliveryRadius     Float    @default(15.0) // km
  minimumDeliveryFee Float    @default(500.0)
  pricePerKm         Float    @default(200.0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model SupportTicket {
  id              String         @id @default(uuid())
  ticketNumber    String         @unique // e.g. TCK-1001
  type            String         // "ORDER_ISSUE", "PAYMENT_ISSUE", "GENERAL"
  priority        TicketPriority @default(MEDIUM)
  status          TicketStatus   @default(OPEN)
  description     String
  customerId      String?
  merchantId      String?
  courierId       String?
  orderId         String?
  assignedAdminId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  resolvedAt      DateTime?
}

model AuditLog {
  id         String   @id @default(uuid())
  adminId    String
  action     String   // e.g. "ADMIN_APPROVED_MERCHANT", "ADMIN_CANCELLED_ORDER"
  entityType String   // e.g. "MERCHANT", "ORDER", "COURIER", "PAYMENT", "COVERAGE"
  entityId   String
  beforeData String?
  afterData  String?
  ipAddress  String?
  createdAt  DateTime @default(now())
}

model PlatformSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String
  createdAt DateTime @default(now())
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
}


